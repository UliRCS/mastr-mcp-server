# MaStR Webdienst Credentials — copy this file to .env and fill in your values.
#
# The server loads these via python-dotenv at startup.
# Existing OS environment variables override .env values.

# Your registered Marktakteur MaStR-Nummer (format: SEM... or SOM...)
MASTR_USER=

# Your MaStR Webdienst-Key (about 540 characters)
MASTR_TOKEN=

# Optional: override the WSDL URL (default points to the production endpoint)
# MASTR_WSDL_URL=https://www.marktstammdatenregister.de/MaStRAPI/wsdl/mastr.wsdl
